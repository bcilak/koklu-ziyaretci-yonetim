{
  "name": "ziyaretci-sistemi",
  "private": true,
  "version": "1.0.0",
  "description": "Köklü Zeytincilik dijital ziyaretçi yönetim sistemi",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build --emptyOutDir",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "db:init": "node server/init-db.js",
    "test": "node tests/database.mjs",
    "deploy:check": "vite build --emptyOutDir && node --check server/index.js && node --check server/init-db.js"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.3",
    "pg-mem": "^3.0.14",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "pg": "^8.22.0",
    "react-qr-code": "^2.0.21"
  },
  "engines": {
    "node": ">=18.18"
  }
}
